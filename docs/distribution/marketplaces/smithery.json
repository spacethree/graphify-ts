{
  "name": "graphify-ts",
  "displayName": "graphify-ts",
  "description": "Local-first MCP server and TypeScript CLI for codebase Q&A and diff-aware PR review with a generated knowledge graph.",
  "transport": "stdio",
  "auth": "none",
  "homepage": "https://github.com/mohanagy/graphify-ts#readme",
  "repository": "https://github.com/mohanagy/graphify-ts",
  "package": {
    "registry": "npm",
    "name": "@mohammednagy/graphify-ts",
    "version": "0.10.8",
    "url": "https://www.npmjs.com/package/@mohammednagy/graphify-ts"
  },
  "license": "MIT",
  "runtime": {
    "node": ">=20"
  },
  "server": {
    "distribution": "local",
    "transport": "stdio",
    "entrypoint": "graphify-ts"
  },
  "install": {
    "command": "npm install -g @mohammednagy/graphify-ts",
    "quickstart": [
      "graphify-ts generate .",
      "graphify-ts claude install"
    ],
    "agentInstalls": [
      "graphify-ts cursor install",
      "graphify-ts copilot install",
      "graphify-ts gemini install",
      "graphify-ts aider install"
    ]
  },
  "tools": {
    "defaultProfile": [
      "retrieve",
      "impact",
      "call_chain",
      "community_overview",
      "pr_impact",
      "graph_stats"
    ],
    "fullProfileCount": 21
  },
  "links": {
    "currentProofHub": "https://github.com/mohanagy/graphify-ts/tree/main/docs/benchmarks",
    "currentRetrievalProof": "https://github.com/mohanagy/graphify-ts/tree/main/docs/benchmarks/2026-04-30-govalidate",
    "currentPrReviewProof": "https://github.com/mohanagy/graphify-ts/tree/main/docs/benchmarks/2026-05-01-govalidate-pr-review",
    "postDeployPages": {
      "benchmarkHub": "https://mohanagy.github.io/graphify-ts/",
      "retrievalBenchmark": "https://mohanagy.github.io/graphify-ts/2026-04-30-govalidate/",
      "prReviewBenchmark": "https://mohanagy.github.io/graphify-ts/2026-05-01-govalidate-pr-review/"
    }
  },
  "notes": [
    "Repo-side draft manifest for future Smithery submission copy.",
    "Grounded in current README, package.json, benchmark docs, and MCP tool definitions.",
    "GitHub Pages URLs are post-deploy only; current proof links point to repo-backed benchmark artifacts on main."
  ]
}
